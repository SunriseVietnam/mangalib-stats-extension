{
  "manifest_version": 3,
  "name": "MangaLib Stats Tracker",
  "version": "1.0.1",
  "description": "Сохраняет и отображает статистику по тайтлам MangaLib",
  "permissions": [
    "storage",
    "declarativeNetRequest"
  ],
  "host_permissions": [
    "https://mangalib.me/*",
    "https://api.cdnlibs.org/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
   "content_scripts": [
    {
      "matches": ["https://mangalib.me/ru/manga/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "browser_specific_settings": {
  "gecko": {
    "id": "{dc040e3e-7ce4-40b7-975f-e9d2261ddaec}",
    "strict_min_version": "140.0",
    "data_collection_permissions": {
      "required": ["none"]
    }
  }
}
}